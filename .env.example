# Local Development (SQLite)
# No environment variables needed for local SQLite

# Vercel Deployment Options:

# Option 1: Vercel Postgres (Recommended)
POSTGRES_URL=postgres://default:password@ep-xxx.us-east-1.aws.neon.tech/dbname
POSTGRES_PRISMA_URL=postgres://default:password@ep-xxx.us-east-1.aws.neon.tech/dbname?pgbouncer=true&connect_timeout=15
POSTGRES_URL_NON_POOLING=postgres://default:password@ep-xxx.us-east-1.aws.neon.tech/dbname

# Option 2: MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/luxestyle

# Option 3: External PostgreSQL
DATABASE_URL=postgresql://username:password@host:port/luxestyle

# Option 4: In-Memory (Demo Only)
# No variables needed - data resets each request

# Application Settings
NODE_ENV=production
PORT=5000
JWT_SECRET=your_jwt_secret_here
